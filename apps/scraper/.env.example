# ── Required ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_tracking

# ── Optional — Redis (queues, circuit breaker) ───────────────────────
REDIS_URL=redis://localhost:6379

# ── Optional — URLs ──────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BASE_URL=https://appranks.io

# ── Optional — SMTP (email sending) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Optional — Error tracking ────────────────────────────────────────
SENTRY_DSN=
NODE_ENV=development

# ── Optional — AI features ───────────────────────────────────────────
OPENAI_API_KEY=

# ── Optional — Linear (auto-create tasks on failures) ────────────────
LINEAR_API_KEY=

# ── Optional — Web Push notifications ────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:push@example.com

# ── Optional — Scraper tuning ────────────────────────────────────────
SCRAPER_DELAY_MS=2000
SCRAPER_MAX_CONCURRENCY=2
BROWSER_POOL_MAX_JOBS=10
BROWSER_POOL_MAX_LIFETIME_MS=3600000

# ── Optional — Circuit breaker ───────────────────────────────────────
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_OPEN_DURATION_MS=3600000

# ── Optional — Proxy ─────────────────────────────────────────────────
# PROXY_URLS=http://proxy1:8080,http://proxy2:8080
# PROXY_ROTATION=round-robin

# ── Optional — Data retention ────────────────────────────────────────
DATA_RETENTION_SNAPSHOT_MONTHS=12
DATA_RETENTION_SCRAPE_RUNS_MONTHS=6
DATA_RETENTION_DLQ_MONTHS=3
