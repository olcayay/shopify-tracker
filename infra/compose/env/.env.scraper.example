# VM2: Scraper Worker
# Values from: terraform output

# Database (Cloud SQL private IP)
DATABASE_URL=postgresql://postgres:PASSWORD@CLOUD_SQL_PRIVATE_IP:5432/appranks

# Redis (Email VM internal IP)
REDIS_URL=redis://EMAIL_VM_INTERNAL_IP:6379

# Scraper
SCRAPER_DELAY_MS=2000
SCRAPER_MAX_CONCURRENCY=2
DASHBOARD_URL=https://appranks.io
NODE_ENV=production

# SMTP (worker sends digest emails)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_XXXXX
SMTP_FROM=AppRanks <noreply@appranks.io>

# External
SENTRY_DSN=

# Monitoring
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_CLOUD_TOKEN=
