# VM3: Email + Notification + Redis
# Values from: terraform output

# Database (Cloud SQL private IP)
DATABASE_URL=postgresql://postgres:PASSWORD@CLOUD_SQL_PRIVATE_IP:5432/appranks

# Redis (localhost — Redis runs on this VM)
REDIS_URL=redis://localhost:6379

# SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_XXXXX
SMTP_FROM=AppRanks <noreply@appranks.io>

# Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:push@appranks.io

# General
DASHBOARD_URL=https://appranks.io
NODE_ENV=production
SENTRY_DSN=

# Monitoring
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_CLOUD_TOKEN=
