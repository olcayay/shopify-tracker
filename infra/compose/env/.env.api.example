# VM1: API + Dashboard
# Values from: terraform output

# Database (Cloud SQL private IP)
DATABASE_URL=postgresql://postgres:PASSWORD@CLOUD_SQL_PRIVATE_IP:5432/appranks

# Redis (Email VM internal IP)
REDIS_URL=redis://EMAIL_VM_INTERNAL_IP:6379

# API
PORT=3001
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
API_KEY=CHANGE_ME
ADMIN_EMAIL=admin@appranks.io
ADMIN_PASSWORD=CHANGE_ME
DASHBOARD_URL=https://appranks.io
NEXT_PUBLIC_API_URL=https://api.appranks.io
NODE_ENV=production

# SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_XXXXX
SMTP_FROM=AppRanks <noreply@appranks.io>

# External APIs
OPENAI_API_KEY=sk-XXXXX
SENTRY_DSN=

# Monitoring (Grafana Cloud)
GRAFANA_LOKI_URL=
GRAFANA_LOKI_USER=
GRAFANA_PROMETHEUS_URL=
GRAFANA_PROM_USER=
GRAFANA_CLOUD_TOKEN=
METRICS_BEARER_TOKEN=
