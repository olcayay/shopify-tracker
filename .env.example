# =============================================================================
# AppRanks Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env — it contains real secrets
# =============================================================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shopify_tracking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=shopify_tracking

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3001
API_KEY=change-me-to-random-string

# Auth
JWT_SECRET=change-me-to-random-string-min-32-chars
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-use-strong-password

# Dashboard
DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

# Scraper
SCRAPER_DELAY_MS=2000
SCRAPER_MAX_CONCURRENCY=2

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM=noreply@example.com

# Email (SMTP Secondary — failover)
SMTP_SECONDARY_HOST=
SMTP_SECONDARY_PORT=587
SMTP_SECONDARY_USER=
SMTP_SECONDARY_PASS=
SMTP_SECONDARY_FROM=

# External APIs
OPENAI_API_KEY=sk-your-openai-key-here

# Linear (for task automation)
LINEAR_API_KEY=lin_api_your-key-here

# Logging
LOG_LEVEL=info

# Observability — Grafana Cloud (free tier: grafana.com)
# Get these from: Grafana Cloud → your stack → Loki/Prometheus details
GRAFANA_LOKI_URL=https://logs-prod-xxx.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=123456
GRAFANA_PROMETHEUS_URL=https://prometheus-prod-xxx.grafana.net/api/prom/push
GRAFANA_PROM_USER=123456
GRAFANA_CLOUD_TOKEN=glc_your-token-here
METRICS_BEARER_TOKEN=change-me-to-random-string
